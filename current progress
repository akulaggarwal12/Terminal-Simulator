#include <iostream>
#include <fstream>
#include <filesystem>
namespace fs = std::filesystem;

void make_file(std::string input, int index) {
    std::string inputPath;
    int flag;
    
    for (int i = index, j=0; input[i] != '\0'; i++, j++) {
        inputPath[j] = input[i];
        inputPath[j+1] = '\0';
    }
    
    fs::path filePath(inputPath);
    
    if (fs::exists(filePath.parent_path())) {
    
        if (fs::exists(filePath)) {
            std::cout << "This File already exists, due to want to replace it: \n";
        
            do {
                std::cout << "1 for Yes else 0: ";
                std::cin >> flag;
                std::cout << "\n";
            } while (flag != 0 && flag != 1) ;
        }
        
        if (!fs::exists(filePath) || flag) {
        
            std::ofstream outFile(filePath, std::ios::app);
            if(outFile.is_open()) {
                // outFile << "File Content";
                std::cout << "File Made";
                outFile.close();
            }
            else
            std::cout << "Error 404";
        }
        else
        std::cout << "Please Rename the File";
    }
    else {
        std::cout << "Directory Path doesnt exist.";
    }
}

int main() {
    std::string input;
    std::cout << "Enter the command: ";
    getline(std::cin, input);
    
    int index;
    std::string command;
    
    for (int i=0; input[i] != ' '; i++) {
        command[i] = input[i];
        command[i+1] = '\0';
        index = i+2;
    }
    
    std::cout << command << "\n";
    
    if (command == "touch")
    make_file(input, index);
    
    return 0;
}
