// Virtual Terminal
void Graphics(fs::path currentpath) {
    int screen_width = 1400, screen_height = 800;
    InitWindow(screen_width ,screen_height , "AETHER");
    
    SetTargetFPS(60);
    
    std::string input = "";
    std::vector<std::string> output;
    int flag = -1;
    
    // Textures Adjustment
        Image image = LoadImage("Image1.png");
        
        ImageResize(&image,screen_width, screen_height - 40);
       
        Texture2D background = LoadTextureFromImage(image);
        
        UnloadImage(image);
        
        std::vector<std::string> data_list;
    
    // Graphics:
    while (!WindowShouldClose()) {
    
        screen_width = GetScreenWidth();
        screen_height = GetScreenHeight();
        
        DrawTexture(background, 0, 40, RAYWHITE);
        
        int key = GetCharPressed();
        
        
        
        // Toggle Full Screen
        if (IsKeyPressed (KEY_F11)) {
        
            ToggleFullscreen();
            screen_width = GetScreenWidth();
            screen_height = GetScreenHeight();
            
            image = LoadImage("Image1.png");
            ImageResize(&image,screen_width, screen_height - 40);
            background = LoadTextureFromImage(image);
            UnloadImage(image);
        }
        
        while (key > 0) {
            if (key >= 32 && key <= 125)
                input += (char)key;
            key = GetCharPressed();
        }
        
        // Deleting
        if (IsKeyPressed(KEY_BACKSPACE) && !input.empty())
            input.pop_back();
        
        // Entering
        if (IsKeyPressed(KEY_ENTER)) {
            output.push_back("user@TechnOS:~ $ " + input);
            std::stringstream ss(input);
            std::string cmd;
            ss >> cmd;
            
            // Command Rule Book
            if (cmd == "touch") {
                flag = touch_file(ss, currentpath);
                std::cout << flag << std::endl;
            }
            else if (cmd == "rename") {
                flag = rename_file(ss, currentpath);
                std::cout << flag << std::endl;
            }
            else if (cmd == "open") {
                flag = open_file(ss, currentpath);
                std::cout << flag << std::endl;
            }
            else if (cmd == "cd") {
                flag = change_dir(ss, &currentpath);
                std::cout << flag << std::endl;
            }
            else if (cmd == "mkdir") {
                flag = make_dir(ss, currentpath);
                std::cout << flag << std::endl;
            }
            else if (cmd == "del") {
                flag = remove(ss, currentpath);
                std::cout << flag << std::endl;
            }
            else if (cmd == "ls") {
                flag = list (currentpath, data_list);
                std::cout << flag << std::endl;
            }
            else if (cmd == "help") {
                flag = 7;
                std::cout << flag << std::endl;
            }
            else if (cmd == "gedit") {
                flag = gedit_file(ss, currentpath);
                std::cout << flag << std::endl;
            }
            else if (cmd == "nano") {
                flag = nano_file(ss, currentpath);
                std::cout << flag << std::endl;
            }
            else {
                flag = 8;
                std::cout << flag << std::endl;
            }
            
            // Reset
            input = "";
        }
        
        //Back Button
        Vector2 mouse_pos = GetMousePosition();
        Vector2 centre = {30.0, 20.0};
        if (IsMouseButtonPressed(MOUSE_BUTTON_LEFT)) {
            if (CheckCollisionPointCircle(mouse_pos, centre, 15.0))
                currentpath = currentpath.parent_path();
        }
        
        
        BeginDrawing();
            ClearBackground(RAYWHITE);
            
            // Ribbon 
            DrawRectangle(0, 0, screen_width, 40, GRAY);
            DrawText(currentpath.c_str(), 60, 10, 20, BLACK);
            DrawText("Press F11 For Fullscreen Toggle", screen_width - MeasureText("Press F11 For Fullscreen Toggle", 20) - 15, 10, 20, BLACK);
            
            // Back Button
            DrawCircle(30, 20, 15.0, BLACK);
            DrawText("<", 25, 7, 30, LIGHTGRAY);
            
            // Previous Commands
            int y = 50;
            for (int i = 0; i < output.size(); i++) {
                DrawText(output[i].c_str(), 20, y, 20, VIOLET);
                y += 20;
            }
            
            // Flags for Different Commands
            if (flag == 0) {
                DrawText("(Given File / Directory Already Exists.)", 20, y, 15, SKYBLUE);
                y += 20;
            }
            else if (flag == 2) {
                DrawText("(Given Command Is Incomplete.)", 20, y, 15, SKYBLUE);
                y += 20;
            }
            else if (flag == 3) {
                DrawText("(Given File / Directory Doesn't Exists.)", 20, y, 15, SKYBLUE);
                y += 20;
            }
            else if (flag == 4) {
                DrawText("(New File Name Already Exists.)", 20, y, 15, SKYBLUE);
                y += 20;
            }
            else if (flag == 5) {
                DrawText("(Items Have Been Deleted)", 20, y, 15, SKYBLUE);
                y += 20;    
            }
            else if (flag == 6) {
                int fontx = 20;
                int fontlen;
                for (int i = 0; i < data_list.size(); i++) {
                    fontlen = MeasureText(data_list[i].c_str(), 20);
                    if (fs::is_directory(currentpath/data_list[i])) {
                        if (fontlen < 150)
                            DrawText(data_list[i].c_str(), fontx, y, 20, DARKBLUE);
                        else
                            DrawText(TextFormat("%.*s...", 11, data_list[i].c_str()), fontx, y, 20, DARKBLUE);
                    }
                    else {
                        if (fontlen < 150)
                            DrawText(data_list[i].c_str(), fontx, y, 20, SKYBLUE);
                        else
                            DrawText(TextFormat("%.*s...", 11, data_list[i].c_str()), fontx, y, 20, SKYBLUE);
                    }
                    
                    fontx += 160;
                    if (fontx > screen_width - 150) {
                        fontx = 20;
                        y += 20;
                    }
                }
                y += 20;
            }
            else if (flag == 7) {
                DrawText("Available Commands are: \n1 - touch filename :: Create the file\n2 - rename oldname newname :: Renaming the file / Folder\n3 - open filename :: Opening the file\n4 - cd directoryname :: Change the Directory\n5 - mkdir directoryname :: Create Directory\n7 - del name :: Deleting File / Folder\n8 - ls :: List of files and folders\n9 - help :: Shows all available commands", 20, y, 20, SKYBLUE);
                y += 20 * 10;
            }
            else if (flag == 8) {
                DrawText("(Invalid Command Given.)", 20, y, 20, SKYBLUE);
                y += 20;
            }
            
            // New Line
            DrawText("user@TechnOS:~ $ ", 20, y + 10, 20, ORANGE);
            DrawText((input).c_str(), 20 + MeasureText("user@TechnOS:~ $ ", 20) + 10, y + 10, 20, GREEN);
        EndDrawing();
    }
    CloseWindow();
}


int main () {
    fs::path root_path = fs::current_path();
    Graphics(root_path);
    return 0;
}
