#include "raylib.h"
#include <iostream>
#include <filesystem>
#include <fstream>
#include <vector>
#include <string>
#include <algorithm>
namespace fs = std::filesystem;

// Virtual Terminal
void Graphics() {
    SetConfigFlags(FLAG_WINDOW_RESIZABLE);
    InitWindow(1000 ,800 , "AETHER");
    SetWindowMinSize(400, 300);
    SetTargetFPS(60);
    
    std::string input = "";
    std::vector<std::string> output;
    
    while (!WindowShouldClose()) {
    
        int screen_width = GetScreenWidth();
        int screen_height = GetScreenHeight();
        
        int key = GetKeyPressed();
        
        while (key > 0) {
            if (key >= 32 && key <= 122)
                input += (char)key;
            key = GetCharPressed();
        }
        
        // Deleting
        if (IsKeyPressed(KEY_BACKSPACE) && !input.empty())
            input.pop_back();
        
        // Entering
        if (IsKeyPressed(KEY_ENTER)) {
            output.push_back("user@TechnOS:~ $ " + input);
            input = "";
        }
        
        BeginDrawing();
            ClearBackground(RAYWHITE);
            DrawRectangle(0, 0, screen_width, 40, GRAY);
            DrawCircle(30, 20, 15.0, BLACK);
            DrawText("<", 25, 7, 30, LIGHTGRAY);
            
            int y = 50;
            for (int i = 0; i < output.size(); i++) {
                DrawText(output[i].c_str(), 20, y, 20, VIOLET);
                y += 20;
            }
            
            DrawText(("user@TechnOS:~ $ " + input).c_str(), 20, y + 10, 20, BLACK);
        EndDrawing();
    }
    CloseWindow();
}


int main () {
    std::string root_path;
    std::cout << "Enter the Root Path: ";
    std::cin >> root_path;
    Graphics();
    
    return 0;
}
